# ── Credenciales de tu app en Shopify Dev Dashboard ──
SHOPIFY_CLIENT_ID=tu_client_id_aqui
SHOPIFY_CLIENT_SECRET=tu_client_secret_aqui

# ── URL pública de tu servidor (usa ngrok en desarrollo) ──
# Ejecuta: ngrok http 3000
# Copia la URL https://xxxx.ngrok.io
APP_URL=https://xxxx.ngrok.io

# ── Permisos que necesita tu app ──
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_customers

# ── Clave para firmar cookies (pon cualquier string aleatorio) ──
COOKIE_SECRET=cambia-esto-por-algo-secreto-largo

# ── Puerto del servidor ──
PORT=3000
